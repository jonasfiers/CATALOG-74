# Used to sign login JWTs -- generate one with `openssl rand -hex 32`
JWT_SECRET=

# How often the nightly batch cycle runs on its own, in milliseconds.
# Default is 24h; set it low (e.g. 60000) if you want to watch it fire
# without waiting -- or just use the "Run batch now" button in the UI.
BATCH_INTERVAL_MS=86400000
